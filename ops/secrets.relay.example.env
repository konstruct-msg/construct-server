# =============================================================================
# Construct Server — Lean Relay Secrets Template
# =============================================================================
# Copy this to /opt/construct/secrets/app.env on the relay server and fill in values.
# Only minimal required secrets for a relay node (no media/TURN/VEIL/MASQUE).
#
#   cp ops/secrets.relay.example.env /opt/construct/secrets/app.env
#   nano /opt/construct/secrets/app.env
#   chmod 600 /opt/construct/secrets/app.env
#
# Relay-specific env (non-secret):
#   cp ops/relay.env.example /opt/construct/.env
#   nano /opt/construct/.env
# =============================================================================

# ── Database (self-hosted PostgreSQL via docker-compose.relay.yml) ────────────
# Docker hostname is "postgres" — same compose network.
# Change PASSWORD to match POSTGRES_PASSWORD in .env
DATABASE_URL="postgres://construct:CHANGE_ME@postgres:5432/construct"

# ── Redis (self-hosted via docker-compose.relay.yml) ─────────────────────────
# Docker hostname is "redis" — same compose network.
# Change PASSWORD to match REDIS_PASSWORD in .env
REDIS_URL="redis://:CHANGE_ME@redis:6379"

# ── PASETO v4.public (Ed25519) — auth tokens ─────────────────────────────────
# Generate:
#   openssl genpkey -algorithm ed25519 -out /opt/construct/secrets/paseto_private_key.pem
#   openssl pkey -in /opt/construct/secrets/paseto_private_key.pem -pubout \
#     -out /opt/construct/secrets/paseto_public_key.pem
PASETO_PRIVATE_KEY="/secrets/paseto_private_key.pem"
PASETO_PUBLIC_KEY="/secrets/paseto_public_key.pem"
TOKEN_ISSUE_FORMAT="paseto"

# ── Signing & HMAC secrets ───────────────────────────────────────────────────
# Generate each with: openssl rand -hex 32
CSRF_SECRET="CHANGE_ME_64_HEX_CHARS"
LOG_HASH_SALT="CHANGE_ME_64_HEX_CHARS"
DELIVERY_SECRET_KEY="CHANGE_ME_64_HEX_CHARS"

# HMAC secret for privacy-preserving contact graph.
# MUST be the same value across all federation nodes that share a user base.
# For a standalone relay, any value is fine.
CONTACT_HMAC_SECRET="CHANGE_ME_64_HEX_CHARS"

# ── Federation (S2S cross-server messaging) ──────────────────────────────────
# REQUIRED if FEDERATION_ENABLED=true.
# Generate: openssl rand -base64 32
SERVER_SIGNING_KEY="CHANGE_ME_BASE64_32_BYTES"

# ── Apple Push Notifications (APNS) — optional for relay ─────────────────────
# Set APNS_ENABLED=false in relay.env to disable. These can be left blank.
APNS_BUNDLE_ID="cc.konstruct.app"
APNS_KEY_ID="TKYQ5KVW7P"
APNS_KEY_PATH="/secrets/AuthKey_TKYQ5KVW7P.p8"
APNS_TEAM_ID=""
APNS_TOPIC="cc.konstruct.app"
APNS_VOIP_TOPIC="cc.konstruct.app.voip"
APNS_DEVICE_TOKEN_ENCRYPTION_KEY=""
