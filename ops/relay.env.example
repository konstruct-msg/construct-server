# =============================================================================
# Construct Server — Lean Relay Compose Variables
# =============================================================================
# Copy this to /opt/construct/.env (project .env for docker compose).
# Non-secret variables only. Secrets go in /opt/construct/secrets/app.env.
#
# All relays MUST change INSTANCE_DOMAIN and IMAGE_TAG.
# =============================================================================

# ── Server Identity ──────────────────────────────────────────────────────────
# The public domain of this relay (e.g., "relay.example.com").
# Used in .well-known/konstruct, federation headers, and Caddy TLS.
INSTANCE_DOMAIN=CHANGE_ME

# ── Image Tag ────────────────────────────────────────────────────────────────
# Docker image tag to deploy (git tag or branch build).
# See https://github.com/konstruct-msg/construct-server/releases
IMAGE_TAG=0.15.0

# ── Database Credentials (must match secrets.relay.example.env) ─────────────
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info,sqlx=warn

# ── Federation ───────────────────────────────────────────────────────────────
# Enable S2S federation. Required for cross-server message delivery.
# Edge relays (no federation) can set to false, but then they're an island.
FEDERATION_ENABLED=true

# Max inbound requests per origin server per hour (sliding window, default 1000).
# FEDERATION_MAX_PER_ORIGIN_PER_HOUR=1000

# ── Push Notifications (APNS) ───────────────────────────────────────────────
# Set to false if no APNS key deployed (relays can skip push).
APNS_ENABLED=false

# ── Message Delivery ─────────────────────────────────────────────────────────
MAX_MESSAGES_PER_HOUR=500
MESSAGE_TTL_DAYS=7
