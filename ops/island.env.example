# =============================================================================
# Construct Server — Domestic-Island Compose Variables
# =============================================================================
# A "domestic island" = 2+ lean relays INSIDE an allowlisted zone, federating
# with each other over HTTPS /federation/v1/*, with NO foreign egress.
#
# Runs on the lean relay profile:
#   docker compose -f ops/docker-compose.relay.yml --env-file .env up -d
# with ops/Caddyfile.island (tls internal — no Let's Encrypt reachability needed).
#
# See construct-docs/decisions/domestic-island-deployment.md for the full plan
# and construct-docs/decisions/whitelist-allowlist-threat-tier.md for the why.
#
# This file shows a worked TWO-NODE example (node-a / node-b). Deploy the
# node-a block on host A, the node-b block on host B. Each host uses ONE .env.
# =============================================================================

# ── Image Tag ────────────────────────────────────────────────────────────────
IMAGE_TAG=0.16.7

# ── Database Credentials (must match secrets.relay.example.env) ─────────────
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
RUST_LOG=info,sqlx=warn

# ── Message Delivery ─────────────────────────────────────────────────────────
MAX_MESSAGES_PER_HOUR=500
MESSAGE_TTL_DAYS=7
APNS_ENABLED=false        # push usually can't leave an allowlisted zone anyway

# =============================================================================
# NODE-A  (deploy this block on host A)
# =============================================================================
# INSTANCE_DOMAIN=relay.a.local
# FEDERATION_BASE_DOMAIN=local
# FEDERATION_ENABLED=true
#
# # Reject unsigned S2S once BOTH nodes have a signing key (start false, flip to true).
# FEDERATION_MTLS_REQUIRED=false
# # Pin check still applies to outbound even with verify=true; keep true.
# FEDERATION_VERIFY_SERVER_CERT=true
# # Pin every PEER by "<peer_domain>:<sha256_spki_hex>" (comma-separated for >1 peer).
# FEDERATION_PINNED_CERTS=relay.b.local:PASTE_SHA256_SPKI_OF_NODE_B
# FEDERATION_MAX_PER_ORIGIN_PER_HOUR=2000
#
# # SECRET — put in /opt/construct/secrets/app.env, NOT here. DISTINCT per node:
# #   SERVER_SIGNING_KEY=<openssl rand -base64 32>

# =============================================================================
# NODE-B  (deploy this block on host B)
# =============================================================================
# INSTANCE_DOMAIN=relay.b.local
# FEDERATION_BASE_DOMAIN=local
# FEDERATION_ENABLED=true
# FEDERATION_MTLS_REQUIRED=false
# FEDERATION_VERIFY_SERVER_CERT=true
# FEDERATION_PINNED_CERTS=relay.a.local:PASTE_SHA256_SPKI_OF_NODE_A
# FEDERATION_MAX_PER_ORIGIN_PER_HOUR=2000
# #   SERVER_SIGNING_KEY=<openssl rand -base64 32>   (distinct from node-a)

# =============================================================================
# Extract a peer's SHA-256 SPKI fingerprint (paste into FEDERATION_PINNED_CERTS):
#
#   openssl s_client -connect relay.b.local:443 -servername relay.b.local </dev/null 2>/dev/null \
#     | openssl x509 -pubkey -noout \
#     | openssl pkey -pubin -outform der \
#     | openssl dgst -sha256 -hex
#
# Sanity-check federation is live and keys are published:
#   curl -sk https://relay.b.local/.well-known/konstruct | jq .federation
# =============================================================================
