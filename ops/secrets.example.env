# =============================================================================
# Construct Server — Secrets Template
# =============================================================================
#
# Copy this to /opt/construct/secrets/app.env on the server and fill in values.
#
#   cp ops/secrets.example.env /opt/construct/secrets/app.env
#   nano /opt/construct/secrets/app.env
#   chmod 600 /opt/construct/secrets/app.env
#
# This file is sourced by all microservices as env_file at startup.
# Never commit the real app.env to git.
# =============================================================================

# ── Database (Supabase or self-hosted PostgreSQL) ────────────────────────────
DATABASE_URL="postgres://user:password@host:5432/dbname"

# ── Redis (Upstash or self-hosted) ───────────────────────────────────────────
REDIS_URL="redis://default:password@host:6379"

# ── JWT (RS256 keypair) — LEGACY, retained for dual-stack verify during migration ─
# Generate: openssl genrsa -out private.pem 4096 && openssl rsa -in private.pem -pubout -out public.pem
# Then base64 encode: base64 -w0 private.pem
# Will be removed after the PASETO migration rotation window completes (Phase 4).
JWT_PRIVATE_KEY="<base64-encoded PEM or raw PEM with \\n escaped>"
JWT_PUBLIC_KEY="<base64-encoded PEM or raw PEM with \\n escaped>"
JWT_ISSUER="ams.konstruct.cc"

# ── PASETO v4.public (Ed25519) — primary auth tokens post-migration ───────────
# Generate:
#   openssl genpkey -algorithm ed25519 -out paseto_private_key.pem
#   openssl pkey -in paseto_private_key.pem -pubout -out paseto_public_key.pem
# Accepts a file path or inline PEM. Recommended: file path (avoids leaking via /proc/environ).
PASETO_PRIVATE_KEY=/path/to/paseto_private_key.pem
PASETO_PUBLIC_KEY=/path/to/paseto_public_key.pem
# Key rotation overlap (optional): during a PASETO key rotation, put the PREVIOUS
# public key(s) here (comma-separated PEM blocks or file paths) so tokens signed by
# the superseded key keep verifying until they expire. Sign always uses the current
# key. Remove entries once metric construct_auth_paseto_verify_key_total{key="previous"}
# hits zero (all old tokens expired — refresh-token TTL). Empty when not rotating.
# PASETO_PUBLIC_KEY_PREVIOUS=/path/to/old_paseto_public_key.pem
# Token format to issue. Verification always accepts both PASETO and legacy JWT
# (dual-stack) so existing sessions rotate naturally during the migration window.
# Values: "paseto" (target) | "jwt" (transitional — verify-only deployments that
# never issue tokens, e.g. user/messaging, may set either; issue is a no-op for them).
TOKEN_ISSUE_FORMAT="paseto"

# ── Signing & HMAC secrets ────────────────────────────────────────────────────
# IMPORTANT: put the raw value with NO surrounding quotes — env_file passes quotes
# literally, so SERVER_SIGNING_KEY="abc" fails base64 decode ("Seed must be 32 bytes").
#
# SERVER_SIGNING_KEY: base64 of exactly 32 bytes — Generate: openssl rand -base64 32
# (federation Ed25519 seed AND, via HKDF, the token-encryption keypair). NOT hex.
SERVER_SIGNING_KEY=
# TOKEN_ISSUER_KEY: Privacy Pass VOPRF issuer scalar — 64 hex chars (32 bytes).
# Generate: openssl rand -hex 32. MUST be identical in identity-service and
# messaging-service (issuance vs redemption). Empty ⇒ IssueTokens/redemption disabled.
TOKEN_ISSUER_KEY=
# TOKEN_ISSUER_KEY_VERSION: integer version of the committed issuer key (Phase C verifiable VOPRF).
# Published in well-known as token_issuer_key_version + echoed in IssueTokensResponse; clients pin
# the commitment K=k·G per version. Bump this whenever TOKEN_ISSUER_KEY rotates. Default 1.
TOKEN_ISSUER_KEY_VERSION=1
# The rest below: openssl rand -hex 32
CSRF_SECRET=
MEDIA_HMAC_SECRET=
LOG_HASH_SALT=
DELIVERY_SECRET_KEY=

# HMAC secret for privacy-preserving contact graph (contact_links table).
# MUST be the same value in user-service and signaling-service.
# Generate: openssl rand -hex 32
# WARNING: changing this invalidates all existing contact_links — requires data migration.
CONTACT_HMAC_SECRET=""

# HMAC-SHA1 secret for TURN server temporary credentials (RFC 8489).
# MUST match `static-auth-secret` in /etc/turnserver.conf on ALL TURN servers.
# Generate: openssl rand -hex 32
TURN_SECRET=""
TURN_CREDENTIALS_TTL_SECONDS=3600

# ── Apple Push Notifications (APNS) ──────────────────────────────────────────
APNS_BUNDLE_ID="cc.konstruct.app"
APNS_KEY_ID="TKYQ5KVW7P"
APNS_KEY_PATH="/secrets/AuthKey_TKYQ5KVW7P.p8"
APNS_TEAM_ID=""
APNS_TOPIC="cc.konstruct.app"
# VoIP push topic for incoming calls (PushKit). MUST be set for calls to work.
# Value = bundle ID + ".voip", e.g. "cc.konstruct.app.voip"
# Without this, callee never receives incoming call notification (silently skipped).
APNS_VOIP_TOPIC="cc.konstruct.app.voip"
APNS_DEVICE_TOKEN_ENCRYPTION_KEY=""

# ── VEIL (obfs4 censorship circumvention) — optional ──────────────────────────
# Generate: run `gateway --keygen` or use the keygen binary
ICE_SERVER_KEY=""
# IAT obfuscation mode: 0=none, 1=enabled, 2=paranoid (recommended for high-threat)
ICE_IAT_MODE=1
# Cover proxy upstream — active probe resistance (Telemt-style)
# Example: ICE_COVER_UPSTREAM="93.184.216.34:443"
# ICE_COVER_UPSTREAM=""
# ── VEIL Relay (standalone relay node) ────────────────────────────────────────
# On a standalone relay, ICE_UPSTREAM must point to the main server's plain h2c
# (HTTP/2 cleartext) Envoy endpoint — NOT to ams.konstruct.cc:443 (TLS).
# The gateway does raw TCP proxy; it does not add TLS on the upstream connection.
#
# Option A: open Envoy port 8080 on the main server firewall → relay IP only.
#   ICE_UPSTREAM="<main-server-ip>:8080"
# Option B: run Envoy locally on the relay, forwarding to main server via TLS upstream.
#   ICE_UPSTREAM="envoy:8080"   (then add envoy to the relay's docker-compose)
#
# Default "envoy:8080" only works on the main server (same Docker network).
# ICE_UPSTREAM="<main-server-ip>:8080"

# ── MASQUE-lite relay (iOS QUIC tunnel) ──────────────────────────────────────
# Optional bearer token. If set, iOS clients must include it as Bearer auth on
# the WebSocket upgrade request. Empty = no auth (insecure, dev only).
# Generate: openssl rand -hex 32
MASQUE_AUTH_TOKEN=""
